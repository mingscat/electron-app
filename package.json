{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "Electron app: vscode 风格 IPC 通信",
  "main": "./out/main/index.js",
  "author": "",
  "scripts": {
    "dev": "electron-vite build && electron-vite dev",
    "build": "electron-vite build",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "dist:all": "pnpm run build && electron-builder -mwl",
    "dist:fast": "pnpm run build && electron-builder --dir",
    "dist:prod": "pnpm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "electron-store": "^8.2.0",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^38.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-builder",
      "electron-winstaller"
    ]
  }
}
